# Ambiente virtual
.venv/

# Variáveis de ambiente (nunca commitar segredos)
.env

# Cache Python
**/__pycache__/
*.pyc
*.pyo

# Banco de dados (gerado localmente via flask db upgrade)
instance/

# Uploads dos usuários (conteúdo gerado em runtime)
app/static/uploads/*
!app/static/uploads/.gitkeep

# Build e distribuição
dist/
build/
*.egg-info/

# Cache do ruff
.ruff_cache/

# Backups
*.bak
